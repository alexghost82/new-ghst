# ---------------------------------------------------------------------------
# Ghost backend configuration. Copy to `.env` and fill in real values.
# Every key below maps to a field in app/config.py (env names are the
# upper-cased field names). Only the most operationally important ones are
# listed here; see app/config.py for the full set of tunables.
# ---------------------------------------------------------------------------

# REQUIRED. Fernet key used to encrypt operator API keys at rest. The backend
# refuses to start if this is missing or left as the placeholder. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GHOST_MASTER_KEY=change-me-to-a-random-fernet-key

# Optional server-side fallback OpenAI key (per-user keys are used by default).
OPENAI_API_KEY=sk-...

# REQUIRED for the public demo/trial flow. Shared OpenAI key used SERVER-SIDE
# only by /users/demo/* — never shipped to the browser.
GHOST_DEMO_API_KEY=sk-...

# Authorization code an operator must present to provision new operators.
# Server-verified via /users/verify-gm. Empty disables provisioning.
GHOST_GM_CODE=

# Shared secret guarding internal admin/PII endpoints (download leads, job
# applications, trial-account roster, magic-link minting). Presented by the
# client via the X-Ghost-Admin-Token header. Empty = those endpoints are CLOSED.
GHOST_ADMIN_TOKEN=

# ---------------------------------------------------------------------------
# Owner / Super-Admin panel (/admin). Separate auth domain: email + password +
# TOTP 2FA, signed into JWTs. Bootstrap the first owner with:
#   python scripts/create_admin.py --email you@example.com --role owner
# ---------------------------------------------------------------------------
# Optional but RECOMMENDED in production: dedicated signing secret for admin
# JWTs. If empty, a value is derived from GHOST_MASTER_KEY (works out of the
# box). Generate a strong random string: python -c "import secrets;print(secrets.token_urlsafe(48))"
GHOST_ADMIN_JWT_SECRET=
# Admin session tuning (optional; defaults shown).
# ADMIN_ACCESS_TTL_MINUTES=30
# ADMIN_REFRESH_TTL_DAYS=7
# Persistent Owner / Super-Admin seed. When BOTH are set, an owner account with
# this email is created on startup IF it does not already exist (an existing
# account's password is never overwritten — rotate via scripts/create_admin.py).
GHOST_OWNER_EMAIL=
GHOST_OWNER_PASSWORD=

DATABASE_PATH=./data/ghost.db
CHROMA_PATH=./data/chroma
UPLOAD_PATH=./data/uploads
HOST=127.0.0.1
PORT=8000

# Observability (optional). Set SENTRY_DSN to enable error reporting.
SENTRY_DSN=
ENVIRONMENT=development

# Vision model overrides (optional) — see app/config.py for defaults & docs.
# GHOST_VISION_MODEL=gpt-5
# GHOST_ALERT_VISION_MODEL=gpt-4o-mini
