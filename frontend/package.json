{
  "name": "ghost-internal-interface",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "gen:knowledge": "node ../scripts/gen-ghost-knowledge.mjs",
    "build": "npm run gen:knowledge && tsc -b && vite build",
    "preview": "vite preview",
    "copy:mediapipe-wasm": "mkdir -p public/mediapipe/wasm && cp -f node_modules/@mediapipe/tasks-vision/wasm/* public/mediapipe/wasm/",
    "postinstall": "npm run copy:mediapipe-wasm || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tanstack/react-virtual": "^3.13.25",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.12",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
