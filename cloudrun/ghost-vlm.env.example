# ghost-vlm — Cloud Run GPU (vLLM / OpenAI-compatible)
# Copy to your shell or CI vars before: bash scripts/deploy-ghost-vlm.sh
#
# Required secrets (stored in Secret Manager by the deploy script):
#   HF_TOKEN            — Hugging Face token for gated models (e.g. Qwen-VL)
#   LOCAL_VLM_API_KEY   — Shared bearer token; ghost-vlm validates Authorization header

PROJECT_ID=ghst-ebb50
REGION=us-central1
SERVICE=ghost-vlm

# Model served by vLLM (must match LOCAL_VLM_MODEL on ghost-api)
LOCAL_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct

# GPU service sizing (L4 requires >= 4 CPU, >= 16Gi; 32Gi recommended for 8B VL)
MEMORY=32Gi
CPU=8
TIMEOUT=3600
CONCURRENCY=1
MAX_INSTANCES=2

# Cold start vs cost:
#   0 — scale to zero when idle (first request after idle can take 1–3+ minutes)
#   1 — keep one warm GPU instance (lower latency, continuous GPU billing)
MIN_INSTANCES=0

# Provide at deploy time (never commit real values):
# export HF_TOKEN=hf_...
# export LOCAL_VLM_API_KEY="$(python3 -c 'import secrets; print(secrets.token_urlsafe(32))')"
