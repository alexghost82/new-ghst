# ghost-api (ghst-api) — Cloud Run, no GPU, wired to ghost-vlm
# Copy to your shell or CI vars before: bash scripts/deploy-ghost-api.sh
#
# LOCAL_VLM_BASE_URL must be the service root WITHOUT /v1 — the backend client
# appends /v1/chat/completions (see backend/app/services/local_vlm.py).

PROJECT_ID=ghst-ebb50
REGION=us-central1
SERVICE=ghst-api

# Auto-discovered from deployed ghost-vlm when unset:
# GHOST_VLM_URL=https://ghost-vlm-xxxxx-uc.a.run.app

LOCAL_VLM_ENABLED=true
LOCAL_VLM_BASE_URL=https://ghost-vlm-xxxxx-uc.a.run.app
LOCAL_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
GHOST_VISION_PROVIDER=auto
LOCAL_VLM_TIMEOUT_SECONDS=180

# Must match the LOCAL_VLM_API_KEY secret on ghost-vlm (deploy script wires both).
# export LOCAL_VLM_API_KEY=...

# Existing ghst-api secrets (same as scripts/deploy-firebase.sh):
# export OPENAI_API_KEY=sk-...
# export GHOST_DEMO_API_KEY=...
# export GHOST_MASTER_KEY=...
# export GHOST_ADMIN_TOKEN=...
